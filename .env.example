# Hostname of the vibe-kanban container (Docker service name or IP)
VIBE_KANBAN_HOST=vibe-kanban

# Port vibe-kanban listens on (default: 4000)
VIBE_KANBAN_PORT=4000

# Optional: scope new issues to a specific project ID (leave blank for no project)
VIBE_KANBAN_PROJECT_ID=

# Optional: restrict who can submit (leave blank for open access)
SUBMIT_TOKEN=
